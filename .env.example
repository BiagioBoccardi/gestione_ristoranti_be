# Copia questo file in .env e compila i valori prima di avviare docker-compose

# Database PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=cambia_questa_password

# JWT - genera una stringa casuale di almeno 64 caratteri
JWT_SECRET=genera_un_segreto_lungo_almeno_256bit_da_sostituire

# Email (Gmail App Password)
MAIL_PASSWORD=app_password_gmail

# URL pubblico del frontend (usato per CORS e link QR code)
# Lascia http://localhost per deploy locale Docker
APP_BASE_URL=http://localhost

# Password dell'account admin iniziale (creato solo al primo avvio se non esiste)
ADMIN_DEFAULT_PASSWORD=cambia_questa_password_admin

# Docker Hub — nome utente (es. miouser → miouser/gestione-ristorante-backend)
DOCKER_HUB_USERNAME=tuo_username_dockerhub

# Grafana — password per l'utente admin (default: admin)
GRAFANA_PASSWORD=cambia_questa_password_grafana
