{
  "__inputs": [],
  "__elements": {},
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "description": "Overview metriche backend Spring Boot - Gestione Ristorante",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Stato Backend",
      "description": "1 = UP, 0 = DOWN",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green", "index": 0 } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red",   "index": 1 } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "up{job=\"gestione-ristorante-backend\"}",
          "legendFormat": "backend",
          "instant": true
        }
      ]
    },

    {
      "id": 2,
      "type": "timeseries",
      "title": "Richieste HTTP al secondo",
      "gridPos": { "h": 8, "w": 10, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line",
            "lineInterpolation": "smooth", "spanNulls": false, "showPoints": "never"
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "sum(rate(http_server_requests_seconds_count{job=\"gestione-ristorante-backend\"}[1m])) by (uri, method, status)",
          "legendFormat": "{{method}} {{uri}} ({{status}})"
        }
      ]
    },

    {
      "id": 3,
      "type": "stat",
      "title": "Connessioni HikariCP attive",
      "gridPos": { "h": 4, "w": 4, "x": 14, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area", "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red",    "value": 9 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "hikaricp_connections_active{job=\"gestione-ristorante-backend\"}",
          "legendFormat": "active",
          "instant": true
        }
      ]
    },

    {
      "id": 4,
      "type": "timeseries",
      "title": "Latenza HTTP — p95 / p99",
      "gridPos": { "h": 8, "w": 10, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2, "fillOpacity": 8, "drawStyle": "line",
            "lineInterpolation": "smooth", "spanNulls": false, "showPoints": "never"
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"gestione-ristorante-backend\"}[2m])) by (le, uri))",
          "legendFormat": "p95 {{uri}}"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"gestione-ristorante-backend\"}[2m])) by (le, uri))",
          "legendFormat": "p99 {{uri}}"
        }
      ]
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Memoria JVM — Heap Used / Max",
      "gridPos": { "h": 8, "w": 10, "x": 10, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2, "fillOpacity": 15, "drawStyle": "line",
            "lineInterpolation": "smooth", "spanNulls": false, "showPoints": "never"
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "jvm_memory_used_bytes{job=\"gestione-ristorante-backend\", area=\"heap\"}",
          "legendFormat": "Heap Used"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "jvm_memory_max_bytes{job=\"gestione-ristorante-backend\", area=\"heap\"}",
          "legendFormat": "Heap Max"
        }
      ]
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "HikariCP — Connessioni Pool",
      "gridPos": { "h": 6, "w": 6, "x": 14, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
      "options": {
        "tooltip": { "mode": "multi", "sort": "none" },
        "legend": { "displayMode": "list", "placement": "bottom", "showLegend": true }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2, "fillOpacity": 10, "drawStyle": "line",
            "lineInterpolation": "smooth", "spanNulls": false, "showPoints": "never"
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "hikaricp_connections_active{job=\"gestione-ristorante-backend\"}",
          "legendFormat": "Active"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "hikaricp_connections_idle{job=\"gestione-ristorante-backend\"}",
          "legendFormat": "Idle"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus-ristorante" },
          "expr": "hikaricp_connections_pending{job=\"gestione-ristorante-backend\"}",
          "legendFormat": "Pending"
        }
      ]
    }

  ],

  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["spring-boot", "gestione-ristorante"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Backend Overview — Gestione Ristorante",
  "uid": "gestione-ristorante-backend",
  "version": 1,
  "weekStart": ""
}
